{
  "name": "@threadbase-sh/scanner",
  "version": "0.12.0",
  "description": "Unified Claude Code conversation history scanner",
  "license": "MIT",
  "author": {
    "name": "Ronen Mars",
    "email": "ronenmars@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RonenMars/threadbase-scanner.git"
  },
  "bugs": {
    "url": "https://github.com/RonenMars/threadbase-scanner/issues"
  },
  "homepage": "https://github.com/RonenMars/threadbase-scanner#readme",
  "keywords": [
    "claude-code",
    "jsonl",
    "scanner",
    "conversation-history",
    "flexsearch",
    "cli"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "threadbase-scanner": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scripts": "vitest run __tests__/scripts",
    "lint": "tsc --noEmit && npx biome check .",
    "format": "npx biome format --write .",
    "check": "npx biome check --write .",
    "capture-live": "bash scripts/capture-live.sh",
    "update-baseline": "bash scripts/update-baseline.sh"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chokidar": "^5.0.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "flexsearch": "^0.8.212",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
